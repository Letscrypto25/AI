# ============================================================
# Helper Bot — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Your Base44 App ID (found in Base44 dashboard → App Settings)
VITE_BASE44_APP_ID=your_app_id_here

# Base44 API base URL — leave as-is unless self-hosting the platform
VITE_BASE44_APP_BASE_URL=https://api.base44.com

# Functions version — leave as-is unless you have a custom build
VITE_BASE44_FUNCTIONS_VERSION=prod

# ============================================================
# Self-Hosting Notes
# ============================================================
# 1. npm install
# 2. Copy .env.example to .env and set VITE_BASE44_APP_ID
# 3. npm run dev        → local dev server
# 4. npm run build      → production build in /dist
# 5. npm run preview    → preview production build locally
#
# Database & auth are handled by the Base44 platform.
# Point VITE_BASE44_APP_BASE_URL to your self-hosted Base44
# instance if running the backend yourself.
# ============================================================
