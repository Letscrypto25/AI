PORT=3000

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional fallback if you only want anon-key reads/writes under your policies.
SUPABASE_ANON_KEY=
# Supabase Postgres pooler URL for direct DB tools/migrations when needed.
DATABASE_URL=

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Buddy security
# Set this before deploying. The UI stores it locally and sends it as x-buddy-token.
BUDDY_ACCESS_TOKEN=

# Terminal is disabled until this is explicitly set to true.
BUDDY_ALLOW_TERMINAL=false
BUDDY_COMMAND_TIMEOUT_MS=20000
